generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?

  repescagemEmpreendimentos RepescagemEmpreendimento[]
  oppSemanas               OppSemana[]
  oppItems                  OppItem[]
  lostGrupos                LostGrupo[]
  lostDisparos              LostDisparo[]
  lostHistoricos            LostHistorico[]
  briefings                 Briefing[]
  metas                      Meta[]
  artefatos                  ArtefatoConfig[]
  campanhas                  Campanha[]
}

model RepescagemEmpreendimento {
  id                    String   @id @default(cuid())
  nomeEmpreendimento    String
  textoConteudo         String?
  linkImagem            String?
  dataUltimaAtualizacao DateTime?
  atualizadoPor         String?
  criadoPorId           String?
  criadoPor             User?    @relation(fields: [criadoPorId], references: [id])
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt
  editadoManualmente    Boolean  @default(false)
  numeros               RepescagemNumero[]
}

model RepescagemNumero {
  id               String   @id @default(cuid())
  campoNome        String
  valorAtual       String?
  dataChecksum     DateTime?
  sinalizador      String?
  verificado       Boolean  @default(false)
  dataVerificado   DateTime?
  empreendimentoId String
  empreendimento   RepescagemEmpreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  criadoEm        DateTime @default(now())
}

model OppSemana {
  id          String     @id @default(cuid())
  weekStart   DateTime   @unique
  metaSemana  Float?
  observacoes String?
  criadoPorId String?
  criadoPor  User?      @relation(fields: [criadoPorId], references: [id])
  criadoEm    DateTime   @default(now())
  items       OppItem[]
}

model OppItem {
  id                 String    @id @default(cuid())
  nomeEmpreendimento String
  localizacao        String?
  preco              String?
  condicoes          String?
  destaque           Boolean   @default(false)
  tipoDestaque       String?
  justificativa      String?
  textoWhatsapp      String?
  textoEmail         String?
  observacoes        String?
  Disparado          Boolean   @default(false)
  dataDisparo        DateTime?
  comentarioDisparo  String?
  semanaId           String
  semana             OppSemana @relation(fields: [semanaId], references: [id], onDelete: Cascade)
  criadoPorId        String?
  criadoPor          User?     @relation(fields: [criadoPorId], references: [id])
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt
}

model LostGrupo {
  id         String        @id @default(cuid())
  nomeMotivo String
  Disparos   LostDisparo[]
  criadoPorId String?
  criadoPor  User?         @relation(fields: [criadoPorId], references: [id])
  criadoEm   DateTime      @default(now())
  atualizadoEm DateTime   @updatedAt
}

model LostDisparo {
  id                    String         @id @default(cuid())
  dataDisparo           DateTime?
  dataRangeInicio       DateTime?
  dataRangeFim          DateTime?
  etapaFiltro           String?
  textoEmail            String?
  textoWhatsapp         String?
  statusDisparo         String         @default("rascunho")
  comentarioNaoDisparo  String?
  Disparado             Boolean        @default(false)
  comentarioDisparo    String?
  grupoId               String
  grupo                 LostGrupo      @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  criadoPorId           String?
  criadoPor             User?          @relation(fields: [criadoPorId], references: [id])
  criadoEm              DateTime       @default(now())
  atualizadoEm          DateTime       @updatedAt
  historico             LostHistorico[]
}

model LostHistorico {
  id         String       @id @default(cuid())
  tipoEvento String
  comentario String?
  dataEvento DateTime     @default(now())
  disparoId  String
  disparo    LostDisparo  @relation(fields: [disparoId], references: [id], onDelete: Cascade)
  criadoPorId String?
  criadoPor  User?        @relation(fields: [criadoPorId], references: [id])
}

model Briefing {
  id             String    @id @default(cuid())
  titulo          String
  empresa         String?
  canal           String?
  formularioJson  Json?
  status          String    @default("rascunho")
  codigoProtecao  String?
  criadoPorId     String
  criadoPor       User      @relation(fields: [criadoPorId], references: [id])
  criadoEm        DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
  dataPublicacao  DateTime?
}

model Meta {
  id                 String   @id @default(cuid())
  trimestre          String
  metaNome            String
  tipo               String
  valorMeta          Float
  valorAtual         Float    @default(0)
  metricasPeriodicas Json?
  criadoPorId        String
  criadoPor          User     @relation(fields: [criadoPorId], references: [id])
  criadoEm           DateTime @default(now())
  atualizadoEm      DateTime @updatedAt
}

model ArtefatoConfig {
  id                String   @id @default(cuid())
  tipo              String
  titulo            String
  descricao         String?
  descricaoDados    String?
  configuracaoJson  Json?
  criadoPorId       String
  criadoPor         User     @relation(fields: [criadoPorId], references: [id])
  criadoEm          DateTime @default(now())
  atualizadoEm     DateTime @updatedAt
}

model LostBoard {
  id         String   @id @default(cuid())
  boardData  Json     // groups, cards, sections, abordagens
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Campanha {
  id         String   @id @default(cuid())
  nome       String
  contexto   String?
  links      Json     // [{titulo: string, url: string}]
  ordem      Int      @default(0)
  criadoPorId String?
  criadoPor  User?    @relation(fields: [criadoPorId], references: [id])
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ── Mídia Paga ────────────────────────────────────────────────────────────────

model MidiaPagaMes {
  id               String   @id @default(cuid())
  mes              String   @unique // YYYY-MM, ex: "2026-05"
  estrategia       String?  // Gatilho de teste nos criativos
  campanhasAtivas  String?  // Campanhas já ativas
  briefingsZerados String? // Empreendimentos que precisam de briefing
  criadoEm         DateTime @default(now())
  priorities       MidiaPagaPrioridade[]
}

model Empreendimento {
  id        String   @id @default(cuid())
  nome      String   @unique
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())
  priorities MidiaPagaPrioridade[]
}

model MidiaPagaPrioridade {
  id               String   @id @default(cuid())
  mesId            String
  mes              MidiaPagaMes @relation(fields: [mesId], references: [id], onDelete: Cascade)
  empreendimentoId String
  empreendimento   Empreendimento @relation(fields: [empreendimentoId], references: [id], onDelete: Cascade)
  criadoEm         DateTime @default(now())
  formatos         MidiaPagaFormato[]
}

model MidiaPagaFormato {
  id             String   @id @default(cuid())
  prioridadeId   String
  prioridade     MidiaPagaPrioridade @relation(fields: [prioridadeId], references: [id], onDelete: Cascade)
  nome           String   // ex: "Estático", "Vídeo Narrado"
  checked        Boolean  @default(false)
  criadoEm       DateTime @default(now())
  estruturas     MidiaPagaEstrutura[]
}

model MidiaPagaEstrutura {
  id        String   @id @default(cuid())
  formatoId String
  formato   MidiaPagaFormato @relation(fields: [formatoId], references: [id], onDelete: Cascade)
  nome      String   // ex: "E1", "E2"
  checked   Boolean  @default(false)
  criadoEm  DateTime @default(now())
  variacoes MidiaPagaVariacao[]
}

model MidiaPagaVariacao {
  id          String   @id @default(cuid())
  estruturaId String
  estrutura   MidiaPagaEstrutura @relation(fields: [estruturaId], references: [id], onDelete: Cascade)
  nome        String   // ex: "V1", "V2"
  checked     Boolean  @default(false)
}

model AnaliseClaude {
  id          String   @id @default(cuid())
  descricao   String
  links       Json     // [{url: string, label: string}]
  dataAnalise DateTime
  criadoEm   DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}
